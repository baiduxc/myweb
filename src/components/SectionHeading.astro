---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-10">
  <h2 class="font-kai text-2xl text-xuan tracking-widest">{title}</h2>
  {subtitle && <p class="mt-2 text-sm text-mo-light font-song">{subtitle}</p>}
  <div class="section-divider"></div>
</div>
