---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';
import { siteName } from '@data/site';

const allPosts = await getCollection('blog');
const posts = allPosts.filter((p) => !p.data.draft && p.data.category === 'zhouyi')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const topics = [
  { title: '六十四卦总论', desc: '卦序、卦名、卦辞、爻辞的系统解读，掌握八卦的基本结构与变化规律。' },
  { title: '上经三十卦', desc: '从乾卦到离卦，论述天道运行之理，涵盖天地万物的生成与演化。' },
  { title: '下经三十四卦', desc: '从咸卦到未济卦，阐述人伦日用之道，指导人事处世与修身齐家。' },
  { title: '象数理占', desc: '象数与义理并重，理解卦象背后的自然法则与人生哲理。' },
  { title: '系辞传解读', desc: '孔子所作的系辞传，是理解周易核心思想的钥匙，揭示"变易、不易、简易"三义。' },
  { title: '周易与现代生活', desc: '将古老智慧应用于当代职场、家庭、人际关系，让经典焕发现代价值。' },
];
---

<BaseLayout title={`周易 - ${siteName}`} description="六十四卦精解，系统学习周易八卦的象数理占">
  <Header />

  <!-- Hero -->
  <section class="pt-28 pb-16 bg-gradient-to-br from-paper via-paper-dark to-[#e8e2d4] relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="absolute top-20 right-20 w-96 h-96 opacity-5 taiji-spin hidden lg:block">
      <svg viewBox="0 0 200 200" fill="none"><circle cx="100" cy="100" r="90" stroke="#1a1a1a" stroke-width="2"/><path d="M100 10A90 90 0 0 1 100 190A45 45 0 0 0 100 100A45 45 0 0 1 100 10Z" fill="#1a1a1a"/><circle cx="100" cy="55" r="12" fill="#faf7f0"/><circle cx="100" cy="145" r="12" fill="#1a1a1a"/></svg>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-br from-ink to-ink-light rounded-full flex items-center justify-center shadow-lg">
        <svg class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      </div>
      <h1 class="font-serif-cn text-4xl md:text-5xl font-bold text-ink mb-4">周易八卦</h1>
      <p class="text-lg text-ink-light/70 max-w-2xl mx-auto leading-relaxed">六十四卦精解 · 象数理占并重 · 以现代视角解读千年智慧</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12 fade-in-up">
        <span class="section-label">概述</span>
        <h2 class="section-title">走进周易</h2>
        <div class="section-divider"></div>
      </div>
      <div class="font-sans-cn text-ink-light/80 leading-loose space-y-6 fade-in-up">
        <p>《周易》是中国最古老的经典之一，被誉为"群经之首，大道之源"。它不仅是占卜之书，更是中华文明对宇宙运行规律深刻思考的结晶。</p>
        <p>周易以八卦为基础，推演出六十四卦，每卦六爻，共三百八十四爻。通过卦象、卦辞、爻辞的组合，揭示事物发展变化的规律，为人类行为提供哲学指导。</p>
        <p>学习周易，不是迷信占卜，而是理解古人对"变化"这一永恒主题的智慧洞察——变易中有不变之理，简易中藏深远之道。</p>
      </div>
    </div>
  </section>

  <!-- Topics -->
  <section class="py-16 bg-paper">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12 fade-in-up">
        <span class="section-label">知识体系</span>
        <h2 class="section-title">核心内容</h2>
        <div class="section-divider"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {topics.map((topic, i) => (
          <div class="bg-white rounded-2xl p-6 border border-gold/10 card-hover fade-in-up" style={`transition-delay: ${i * 100}ms;`}>
            <h3 class="font-serif-cn text-lg font-bold text-ink mb-2">{topic.title}</h3>
            <p class="text-sm text-ink-light/70 leading-relaxed">{topic.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Articles -->
  {posts.length > 0 && (
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12 fade-in-up">
          <span class="section-label">相关文章</span>
          <h2 class="section-title">推荐阅读</h2>
          <div class="section-divider"></div>
        </div>
        <div class="space-y-6">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}/`} class="block bg-paper rounded-xl p-6 border border-gold/5 card-hover no-underline fade-in-up">
              <h3 class="font-serif-cn text-lg font-bold text-ink mb-2 hover:text-vermilion transition-colors">{post.data.title}</h3>
              <p class="text-sm text-ink-light/70 line-clamp-2">{post.data.description}</p>
              <div class="text-xs text-ink-light/50 mt-3">
                {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const fadeElements = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    fadeElements.forEach((el) => observer.observe(el));
  });
</script>
