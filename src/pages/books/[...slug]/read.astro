---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((book) => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const rendered = await book.render();
const { Content } = rendered;

const categoryMap = { shan: '山', yi: '医', ming: '命', xiang: '相', bu: '卜' };
const catLabel = categoryMap[book.data.category] || '';

const allBooks = await getCollection('books');
const categoryBooks = allBooks.filter((b) => !b.data.draft && b.data.category === book.data.category)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const currentIndex = categoryBooks.findIndex((b) => b.slug === book.slug);
const prevBook = currentIndex > 0 ? categoryBooks[currentIndex - 1] : null;
const nextBook = currentIndex < categoryBooks.length - 1 ? categoryBooks[currentIndex + 1] : null;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{book.data.title} - 昊天易学网</title>
  <meta name="description" content={book.data.description} />
  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'ink': '#1a1a1a', 'ink-light': '#6b7280', 'paper': '#faf7f0',
            'gold': '#c5a456', 'vermilion': '#c41e3a',
          },
          fontFamily: {
            'serif-cn': ['"Source Han Serif SC"', 'STSong', 'SimSun', 'serif'],
            'sans-cn': ['"PingFang SC"', '"Microsoft YaHei"', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <style>
    .reader-content h2 {
      font-family: 'Source Han Serif SC', 'STSong', 'SimSun', serif;
      font-size: 1.25rem;
      font-weight: 700;
      color: #1a1a1a;
      margin-top: 2.5rem;
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #e5e0d5;
    }
    .reader-content h2:first-child {
      margin-top: 0;
    }
    .reader-content p {
      text-indent: 2em;
      margin-bottom: 1.25rem;
      line-height: 1.9;
      color: #1a1a1a;
    }
    .reader-content blockquote {
      border-left: 3px solid #d4cfc5;
      padding: 0.5rem 0 0.5rem 1rem;
      margin: 1rem 0 1.25rem;
      color: #6b7280;
    }
    .reader-content a {
      color: #c41e3a;
      text-decoration: none;
    }
    .reader-content a:hover {
      text-decoration: underline;
    }
    .reader-content ul, .reader-content ol {
      margin: 1rem 0 1.25rem 2em;
    }
    .reader-content li {
      margin-bottom: 0.5rem;
      line-height: 1.8;
    }
  </style>
</head>
<body class="bg-paper min-h-screen">

  <!-- Top Bar -->
  <div class="sticky top-0 z-40 bg-paper/95 backdrop-blur-sm border-b border-gold/10">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between h-14">
        <!-- Left: Back -->
        <a href={`/books/${book.slug}/`} class="flex items-center gap-1.5 text-sm text-ink-light hover:text-vermilion transition-colors no-underline">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
          <span class="hidden sm:inline">返回</span>
        </a>
        <!-- Center: Breadcrumb -->
        <div class="flex items-center gap-1.5 text-xs text-ink-light/60 truncate max-w-[60vw]">
          <a href="/books/" class="hover:text-ink-light transition-colors no-underline">书库</a>
          {catLabel && (<>
            <span class="text-ink-light/30">/</span>
            <a href={`/books/?filter=${book.data.category}`} class="hover:text-ink-light transition-colors no-underline">{catLabel}</a>
          </>)}
          <span class="text-ink-light/30">/</span>
          <span class="font-serif-cn text-ink-light/80 truncate">{book.data.title}</span>
        </div>
        <!-- Right: Page indicator -->
        <span class="text-xs text-ink-light/50 font-mono shrink-0 ml-2" id="page-indicator"></span>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div id="reader-container" class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="reader-content" id="reader-body"></div>
    <div id="reader-source" class="hidden"><Content /></div>

    <!-- Prev/Next at bottom -->
    <div class="mt-16 pt-8 border-t border-gold/10 flex items-center justify-between" id="nav-bar">
      <a href={prevBook ? `/books/${prevBook.slug}/read/` : '#'}
         class={`flex items-center gap-2 text-sm no-underline ${prevBook ? 'text-ink-light hover:text-vermilion' : 'text-ink-light/30 pointer-events-none'} transition-colors`}>
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        {prevBook?.data.title || '已经是第一篇'}
      </a>
      <a href={nextBook ? `/books/${nextBook.slug}/read/` : '#'}
         class={`flex items-center gap-2 text-sm no-underline ${nextBook ? 'text-ink-light hover:text-vermilion' : 'text-ink-light/30 pointer-events-none'} transition-colors`}>
        {nextBook?.data.title || '已经是最后一篇'}
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </a>
    </div>
  </div>

  <script is:inline>
    // Split content by h2, one section = one page
    function splitPages() {
      const src = document.getElementById('reader-source');
      if (!src) return [];
      const html = src.innerHTML;
      const pages = [];
      const re = /<h2[^>]*>(.*?)<\/h2>/g;
      let last = 0, m;
      while ((m = re.exec(html)) !== null) {
        const sectionHtml = html.slice(last, m.index);
        if (sectionHtml.trim()) pages.push({ title: m[1].replace(/<[^>]+>/g, ''), html: sectionHtml });
        last = m.index + m[0].length;
      }
      if (last < html.length) pages.push({ title: '', html: html.slice(last) });
      if (pages.length === 0 && html.trim()) pages.push({ title: '', html });
      return pages;
    }

    const PAGES = splitPages();
    let currentPage = 0;
    const totalPages = PAGES.length;

    function renderPage(idx) {
      if (idx < 0 || idx >= totalPages) return;
      currentPage = idx;
      document.getElementById('reader-body').innerHTML = PAGES[idx].html;
      const indicator = document.getElementById('page-indicator');
      if (indicator) indicator.textContent = (idx + 1) + ' / ' + totalPages;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function goPage(dir) { renderPage(currentPage + dir); try { localStorage.setItem('reader-page-' + location.pathname, String(currentPage)); } catch {} }

    // Click left/right sides of content to navigate
    document.getElementById('reader-container').addEventListener('click', function(e) {
      if (e.target.closest('a') || e.target.closest('#nav-bar')) return;
      const rect = this.getBoundingClientRect();
      const x = e.clientX - rect.left;
      if (x > rect.width * 0.65) goPage(1);
      else if (x < rect.width * 0.35) goPage(-1);
    });

    // Keyboard
    document.addEventListener('keydown', function(e) {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); goPage(-1); }
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') { e.preventDefault(); goPage(1); }
    });

    // Init
    try {
      const saved = localStorage.getItem('reader-page-' + location.pathname);
      renderPage(saved ? parseInt(saved) : 0);
    } catch { renderPage(0); }
  </script>
</body>
</html>
