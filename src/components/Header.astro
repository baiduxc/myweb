---
import { navLinks, siteName } from '@data/site';
const currentPath = Astro.url.pathname;
---

<header class="border-b border-tan/20 bg-xuan-paper/95 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3 no-underline group">
        <svg class="w-8 h-8 text-zhu group-hover:text-zhu-light transition-colors" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5"/>
          <path d="M24 4C24 4 24 44 24 44" stroke="currentColor" stroke-width="1"/>
          <path d="M4 24C4 24 44 24 44 24" stroke="currentColor" stroke-width="1"/>
          <circle cx="24" cy="24" r="8" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="24" cy="24" r="2" fill="currentColor"/>
          <text x="24" y="17" text-anchor="middle" font-size="8" fill="currentColor" font-family="serif">甲</text>
          <text x="24" y="36" text-anchor="middle" font-size="8" fill="currentColor" font-family="serif">子</text>
          <text x="10" y="27" text-anchor="middle" font-size="8" fill="currentColor" font-family="serif">乾</text>
          <text x="38" y="27" text-anchor="middle" font-size="8" fill="currentColor" font-family="serif">坤</text>
        </svg>
        <span class="font-kai text-lg text-xuan tracking-widest">{siteName}</span>
      </a>

      <nav class="hidden md:flex items-center gap-6" aria-label="主导航">
        {navLinks.map((link) => {
          const isActive = currentPath === link.href;
          return (
            <a
              href={link.href}
              class:list={[isActive ? 'nav-link-active' : 'nav-link']}
            >
              {link.label}
            </a>
          );
        })}
      </nav>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-mo hover:text-zhu transition-colors"
        aria-label="菜单"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-tan/20 bg-xuan-paper">
    <nav class="flex flex-col px-4 py-3 gap-2" aria-label="移动导航">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href;
        return (
          <a
            href={link.href}
            class:list={[
              'py-2 px-3 rounded-sm font-kai text-sm tracking-wider transition-colors no-underline',
              isActive ? 'text-zhu bg-zhu/5' : 'text-mo/80 hover:text-zhu hover:bg-zhu/5'
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
  });
</script>
