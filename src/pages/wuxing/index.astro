---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';
import { siteName } from '@data/site';

const allPosts = await getCollection('blog');
const posts = allPosts.filter((p) => !p.data.draft && p.data.category === 'wuxing')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Each element with its own color palette
const wuxingData = [
  { name: '木', fg: '#ffffff', bg: 'wuxing-jade', gradient: 'from-jade to-jade-light', direction: '东', season: '春', nature: '生发', organ: '肝', emotion: '怒', virtue: '仁', textColor: 'text-white' },
  { name: '火', fg: '#ffffff', bg: 'wuxing-fire', gradient: 'from-vermilion to-vermilion-light', direction: '南', season: '夏', nature: '炎热', organ: '心', emotion: '喜', virtue: '礼', textColor: 'text-white' },
  { name: '土', fg: '#faf7f0', bg: 'wuxing-earth', gradient: 'from-earth to-earth-light', direction: '中', season: '季夏', nature: '承载', organ: '脾', emotion: '思', virtue: '信', textColor: 'text-paper' },
  { name: '金', fg: '#faf7f0', bg: 'wuxing-gold', gradient: 'from-gold to-gold-light', direction: '西', season: '秋', nature: '收敛', organ: '肺', emotion: '悲', virtue: '义', textColor: 'text-paper' },
  { name: '水', fg: '#ffffff', bg: 'wuxing-water', gradient: 'from-water to-water-light', direction: '北', season: '冬', nature: '润下', organ: '肾', emotion: '恐', virtue: '智', textColor: 'text-white' },
];

const shengRelations = [
  { from: '木', to: '火', desc: '木燃烧而生火' },
  { from: '火', to: '土', desc: '火化为灰归于土' },
  { from: '土', to: '金', desc: '金矿藏于土中' },
  { from: '金', to: '水', desc: '金熔化如水流动' },
  { from: '水', to: '木', desc: '水滋养草木生长' },
];

const keRelations = [
  { from: '木', to: '土', desc: '草木根系穿透土壤' },
  { from: '土', to: '水', desc: '堤坝可阻挡水流' },
  { from: '水', to: '火', desc: '水能灭火' },
  { from: '火', to: '金', desc: '火能熔化金属' },
  { from: '金', to: '木', desc: '斧头可砍伐树木' },
];

// Pentagon node positions for SVG
const pentagonNodes = [
  { name: '木', fill: '#4a7c59', fillLight: '#5d9468', fg: '#ffffff', direction: '东', season: '春', organ: '肝', x: 200, y: 55 },
  { name: '火', fill: '#c41e3a', fillLight: '#d43b4f', fg: '#ffffff', direction: '南', season: '夏', organ: '心', x: 352, y: 165 },
  { name: '土', fill: '#8b6914', fillLight: '#a67c2e', fg: '#faf7f0', direction: '中', season: '季夏', organ: '脾', x: 295, y: 340 },
  { name: '金', fill: '#c5a456', fillLight: '#d4b870', fg: '#faf7f0', direction: '西', season: '秋', organ: '肺', x: 105, y: 340 },
  { name: '水', fill: '#2c5f6e', fillLight: '#3d7a8c', fg: '#ffffff', direction: '北', season: '冬', organ: '肾', x: 48, y: 165 },
];

const shengEdges = [[0,1],[1,2],[2,3],[3,4],[4,0]];
const keEdges = [[0,2],[2,4],[4,1],[1,3],[3,0]];
---

<BaseLayout title={`五行基础 - ${siteName}`} description="五行生克制化的深入理解">
  <Header />

  <!-- Hero -->
  <section class="pt-28 pb-16 bg-gradient-to-br from-paper via-paper-dark to-[#e8e2d4] relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-serif-cn text-4xl md:text-5xl font-bold text-ink mb-4">五行基础</h1>
      <p class="text-lg text-ink-light/70 max-w-2xl mx-auto leading-relaxed">木火土金水 · 相生相克 · 命理学的根本法则</p>
    </div>
  </section>

  <!-- Pentagon SVG Diagram -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12 fade-in-up"><span class="section-label">五行概览</span><h2 class="section-title">五行属性</h2><div class="section-divider"></div></div>

      <div class="flex justify-center mb-12 fade-in-up">
        <div class="relative w-full max-w-[420px]">
          <svg viewBox="0 0 400 400" class="w-full h-auto" xmlns="http://www.w3.org/2000/svg">
            <!-- 相生连线 -->
            {shengEdges.map(([from, to]) => (
              <line x1={pentagonNodes[from].x} y1={pentagonNodes[from].y} x2={pentagonNodes[to].x} y2={pentagonNodes[to].y} stroke="#4a7c59" stroke-width="2.5" stroke-dasharray="6,4" opacity="0.6"/>
            ))}
            <!-- 相克连线 -->
            {keEdges.map(([from, to]) => (
              <line x1={pentagonNodes[from].x} y1={pentagonNodes[from].y} x2={pentagonNodes[to].x} y2={pentagonNodes[to].y} stroke="#c41e3a" stroke-width="2" stroke-dasharray="4,4" opacity="0.4"/>
            ))}
            <!-- 五行节点圆圈 -->
            {pentagonNodes.map((node, i) => (
              <g>
                <circle cx={node.x} cy={node.y} r="44" fill={`url(#grad${i})`} filter="url(#nodeShadow)"/>
                <text x={node.x} y={node.y - 6} text-anchor="middle" fill={node.fg} class="font-serif-cn text-2xl font-bold">{node.name}</text>
                <text x={node.x} y={node.y + 14} text-anchor="middle" fill={node.fg} class="text-[11px]" style="opacity:0.85">{node.direction}·{node.season}</text>
                <text x={node.x} y={node.y + 26} text-anchor="middle" fill={node.fg} class="text-[10px]" style="opacity:0.65">{node.organ}</text>
              </g>
            ))}
            <!-- 相生标签 -->
            <text x="305" y="92" text-anchor="middle" fill="#4a7c59" class="text-[11px]" style="font-weight:500">生</text>
            <text x="340" y="265" text-anchor="middle" fill="#4a7c59" class="text-[11px]" style="font-weight:500">生</text>
            <text x="200" y="378" text-anchor="middle" fill="#4a7c59" class="text-[11px]" style="font-weight:500">生</text>
            <text x="60" y="265" text-anchor="middle" fill="#4a7c59" class="text-[11px]" style="font-weight:500">生</text>
            <text x="95" y="92" text-anchor="middle" fill="#4a7c59" class="text-[11px]" style="font-weight:500">生</text>
            <!-- 相克标签 -->
            <text x="255" y="185" text-anchor="middle" fill="#c41e3a" class="text-[10px]" style="font-weight:500">克</text>
            <text x="175" y="255" text-anchor="middle" fill="#c41e3a" class="text-[10px]" style="font-weight:500">克</text>
            <text x="200" y="140" text-anchor="middle" fill="#c41e3a" class="text-[10px]" style="font-weight:500">克</text>
            <text x="130" y="175" text-anchor="middle" fill="#c41e3a" class="text-[10px]" style="font-weight:500">克</text>
            <text x="270" y="270" text-anchor="middle" fill="#c41e3a" class="text-[10px]" style="font-weight:500">克</text>
            <defs>
              {pentagonNodes.map((node, i) => (
                <linearGradient id={`grad${i}`} x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color={node.fill}/>
                  <stop offset="100%" stop-color={node.fillLight}/>
                </linearGradient>
              ))}
              <filter id="nodeShadow"><feDropShadow dx="0" dy="3" stdDeviation="4" flood-opacity="0.25"/></filter>
            </defs>
          </svg>
        </div>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-8 text-sm fade-in-up">
        <div class="flex items-center gap-2">
          <span class="inline-block w-8" style="border-top: 2.5px dashed #4a7c59;"></span>
          <span class="text-jade font-medium">相生 · 循环滋养</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="inline-block w-8" style="border-top: 2px dashed #c41e3a;"></span>
          <span class="text-vermilion font-medium">相克 · 制约平衡</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Detail Cards - each with its own color -->
  <section class="py-16 bg-paper">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12 fade-in-up"><span class="section-label">五行详解</span><h2 class="section-title">各属性详述</h2><div class="section-divider"></div></div>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
        {wuxingData.map((wx, i) => (
          <div class={`${wx.bg} rounded-2xl p-5 text-center card-hover fade-in-up ${wx.textColor}`}>
            <div class="text-3xl font-serif-cn font-bold mb-3" style="opacity:0.95">{wx.name}</div>
            <div class="text-xs space-y-1.5" style="opacity:0.85">
              <div>方位：{wx.direction}</div>
              <div>季节：{wx.season}</div>
              <div>特性：{wx.nature}</div>
              <div>脏腑：{wx.organ}</div>
              <div>情绪：{wx.emotion}</div>
              <div>德行：{wx.virtue}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sheng Ke Relations -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <div class="fade-in-up">
          <div class="text-center mb-8">
            <span class="text-jade text-sm font-medium tracking-widest">相生循环</span>
            <h3 class="font-serif-cn text-2xl font-bold text-ink mt-2">五行相生</h3>
          </div>
          <div class="space-y-3">
            {shengRelations.map((r) => (
              <div class="bg-paper rounded-xl p-4 flex items-center gap-4 border border-gold/10">
                <span class="font-serif-cn text-lg font-bold text-jade">{r.from} → {r.to}</span>
                <span class="text-sm text-ink-light/70">{r.desc}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="fade-in-up">
          <div class="text-center mb-8">
            <span class="text-vermilion text-sm font-medium tracking-widest">相克循环</span>
            <h3 class="font-serif-cn text-2xl font-bold text-ink mt-2">五行相克</h3>
          </div>
          <div class="space-y-3">
            {keRelations.map((r) => (
              <div class="bg-paper rounded-xl p-4 flex items-center gap-4 border border-gold/10">
                <span class="font-serif-cn text-lg font-bold text-vermilion">{r.from} → {r.to}</span>
                <span class="text-sm text-ink-light/70">{r.desc}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Articles -->
  {posts.length > 0 && (
    <section class="py-16 bg-paper">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12 fade-in-up"><span class="section-label">相关文章</span><h2 class="section-title">推荐阅读</h2><div class="section-divider"></div></div>
        <div class="space-y-6">{posts.map((p) => (<a href={`/blog/${p.slug}/`} class="block bg-white rounded-xl p-6 border border-gold/5 card-hover no-underline fade-in-up"><h3 class="font-serif-cn text-lg font-bold text-ink mb-2 hover:text-vermilion transition-colors">{p.data.title}</h3><p class="text-sm text-ink-light/70 line-clamp-2">{p.data.description}</p><div class="text-xs text-ink-light/50 mt-3">{p.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</div></a>))}</div>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const els = document.querySelectorAll('.fade-in-up');
    const obs = new IntersectionObserver((e) => e.forEach((x) => { if (x.isIntersecting) x.target.classList.add('visible'); }), { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    els.forEach((el) => obs.observe(el));
  });
</script>
