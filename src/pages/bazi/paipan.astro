---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { siteName } from '@data/site';
---

<BaseLayout title={`八字排盘 - ${siteName}`} description="在线四柱八字排盘工具">
  <Header />

  <section class="pt-28 pb-16 bg-gradient-to-br from-paper via-paper-dark to-[#e8e2d4] relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-br from-vermilion to-vermilion-light rounded-full flex items-center justify-center shadow-lg">
        <svg class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      </div>
      <h1 class="font-serif-cn text-4xl md:text-5xl font-bold text-ink mb-4">八字排盘</h1>
      <p class="text-lg text-ink-light/70 max-w-2xl mx-auto leading-relaxed">输入出生年月日时，排出四柱命盘</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Input Form -->
      <div class="bg-paper rounded-2xl p-8 border border-gold/10 max-w-xl mx-auto mb-10 shadow-sm">
        <form id="bazi-form" class="space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="birth-date" class="block text-sm font-serif-cn text-ink mb-1">出生日期</label>
              <input type="date" id="birth-date" required
                class="w-full px-4 py-3 border border-gold/30 rounded-xl bg-white font-sans-cn text-ink focus:border-vermilion focus:outline-none focus:ring-1 focus:ring-vermilion/30" />
            </div>
            <div>
              <label for="birth-time" class="block text-sm font-serif-cn text-ink mb-1">出生时辰</label>
              <select id="birth-time" required
                class="w-full px-4 py-3 border border-gold/30 rounded-xl bg-white font-sans-cn text-ink focus:border-vermilion focus:outline-none focus:ring-1 focus:ring-vermilion/30">
                <option value="">请选择时辰</option>
                <option value="23">子时 (23:00-01:00)</option>
                <option value="1">丑时 (01:00-03:00)</option>
                <option value="3">寅时 (03:00-05:00)</option>
                <option value="5">卯时 (05:00-07:00)</option>
                <option value="7">辰时 (07:00-09:00)</option>
                <option value="9">巳时 (09:00-11:00)</option>
                <option value="11">午时 (11:00-13:00)</option>
                <option value="13">未时 (13:00-15:00)</option>
                <option value="15">申时 (15:00-17:00)</option>
                <option value="17">酉时 (17:00-19:00)</option>
                <option value="19">戌时 (19:00-21:00)</option>
                <option value="21">亥时 (21:00-23:00)</option>
              </select>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <label class="flex items-center gap-2 text-sm font-serif-cn text-ink-light cursor-pointer">
              <input type="radio" name="calendar" value="solar" checked class="text-vermilion focus:ring-vermilion" />
              公历
            </label>
            <label class="flex items-center gap-2 text-sm font-serif-cn text-ink-light cursor-pointer">
              <input type="radio" name="calendar" value="lunar" class="text-vermilion focus:ring-vermilion" />
              农历
            </label>
          </div>
          <button type="submit" class="w-full px-6 py-3 bg-vermilion text-white rounded-xl hover:bg-vermilion-light transition-all duration-300 font-serif-cn tracking-wider">
            开始排盘
          </button>
        </form>
      </div>

      <!-- Result -->
      <div id="bazi-result" class="hidden space-y-8">
        <!-- 四柱命盘 -->
        <div class="bg-paper rounded-2xl p-8 border border-gold/10 shadow-sm">
          <h3 class="font-serif-cn text-xl text-ink text-center mb-8 tracking-widest">四 柱 命 盘</h3>
          <div class="grid grid-cols-4 gap-4 text-center max-w-lg mx-auto">
            <div class="font-serif-cn text-sm text-ink-light">年柱</div>
            <div class="font-serif-cn text-sm text-ink-light">月柱</div>
            <div class="font-serif-cn text-sm text-ink-light">日柱</div>
            <div class="font-serif-cn text-sm text-ink-light">时柱</div>

            <div id="year-gan" class="text-3xl font-serif-cn text-ink py-2"></div>
            <div id="month-gan" class="text-3xl font-serif-cn text-ink py-2"></div>
            <div id="day-gan" class="text-3xl font-serif-cn text-vermilion py-2"></div>
            <div id="hour-gan" class="text-3xl font-serif-cn text-ink py-2"></div>

            <div id="year-zhi" class="text-3xl font-serif-cn text-ink py-2"></div>
            <div id="month-zhi" class="text-3xl font-serif-cn text-ink py-2"></div>
            <div id="day-zhi" class="text-3xl font-serif-cn text-vermilion py-2"></div>
            <div id="hour-zhi" class="text-3xl font-serif-cn text-ink py-2"></div>

            <div id="year-wuxing" class="text-xs text-ink-light/60"></div>
            <div id="month-wuxing" class="text-xs text-ink-light/60"></div>
            <div id="day-wuxing" class="text-xs text-ink-light/60"></div>
            <div id="hour-wuxing" class="text-xs text-ink-light/60"></div>
          </div>

          <div class="w-24 h-1 bg-gradient-to-r from-vermilion to-gold mx-auto my-6"></div>

          <!-- 十神 -->
          <div class="grid grid-cols-4 gap-4 text-center max-w-lg mx-auto mb-4">
            <div id="year-shishen" class="text-sm text-gold font-serif-cn"></div>
            <div id="month-shishen" class="text-sm text-gold font-serif-cn"></div>
            <div class="text-sm text-ink-light/60 font-serif-cn">日主</div>
            <div id="hour-shishen" class="text-sm text-gold font-serif-cn"></div>
          </div>

          <!-- 纳音 -->
          <div class="text-center text-sm text-ink-light/60">
            <span>纳音：</span>
            <span id="nayin-year"></span> · <span id="nayin-month"></span> · <span id="nayin-day"></span> · <span id="nayin-hour"></span>
          </div>
        </div>

        <!-- 五行统计 -->
        <div class="bg-paper rounded-2xl p-8 border border-gold/10 shadow-sm">
          <h3 class="font-serif-cn text-xl text-ink text-center mb-6 tracking-widest">五行统计</h3>
          <div id="wuxing-stats" class="flex items-center justify-center gap-8"></div>
        </div>

        <!-- 藏干 -->
        <div class="bg-paper rounded-2xl p-8 border border-gold/10 shadow-sm">
          <h3 class="font-serif-cn text-xl text-ink text-center mb-6 tracking-widest">地支藏干</h3>
          <div id="canggan-grid" class="grid grid-cols-4 gap-4 text-center max-w-lg mx-auto"></div>
        </div>

        <!-- AI Analysis -->
        <div class="bg-paper rounded-2xl p-8 border border-gold/10 shadow-sm">
          <h3 class="font-serif-cn text-xl text-ink text-center mb-6 tracking-widest">AI 命理简析</h3>
          <div id="ai-analysis" class="font-sans-cn text-ink-light/80 leading-loose text-sm"></div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
import { tianGan, diZhi, ganWuxing, zhiWuxing, ganYinYang, cangGan, shiShenMap, naYin, getShiChenName } from '../../utils/bazi';

function getYearGanZhi(year: number): [string, string] {
  return [tianGan[(year - 4) % 10], diZhi[(year - 4) % 12]];
}

function getMonthGan(year: number, month: number): string {
  const yearGanIndex = (year - 4) % 10;
  const startGan: Record<number, number> = { 0: 2, 5: 2, 1: 4, 6: 4, 2: 6, 7: 6, 3: 8, 8: 8, 4: 0, 9: 0 };
  return tianGan[((startGan[yearGanIndex] ?? 2) + month - 1) % 10];
}

function getMonthZhi(month: number): string {
  return ['寅', '卯', '辰', '巳', '午', '未', '申', '酉', '戌', '亥', '子', '丑'][month - 1] || '寅';
}

function getDayGanZhi(year: number, month: number, day: number): [string, string] {
  const baseDate = new Date(1900, 0, 31);
  const targetDate = new Date(year, month - 1, day);
  const diffDays = Math.floor((targetDate.getTime() - baseDate.getTime()) / (1000 * 60 * 60 * 24));
  return [tianGan[((diffDays) % 10 + 10) % 10], diZhi[((10 + diffDays) % 12 + 12) % 12]];
}

function getHourGan(dayGan: string, hour: number): string {
  const dayGanIndex = tianGan.indexOf(dayGan);
  const startGan: Record<number, number> = { 0: 0, 5: 0, 1: 2, 6: 2, 2: 4, 7: 4, 3: 6, 8: 6, 4: 8, 9: 8 };
  let hourZhiIndex = 0;
  if (hour >= 23 || hour < 1) hourZhiIndex = 0;
  else hourZhiIndex = Math.floor((hour + 1) / 2);
  return tianGan[((startGan[dayGanIndex] ?? 0) + hourZhiIndex) % 10];
}

function getHourZhi(hour: number): string {
  if (hour >= 23 || hour < 1) return '子';
  return ['', '丑', '寅', '卯', '辰', '巳', '午', '未', '申', '酉', '戌', '亥'][Math.floor((hour + 1) / 2)] || '子';
}

function getShiShen(dayGan: string, targetGan: string): string {
  return shiShenMap[dayGan]?.[targetGan] || '';
}

const form = document.getElementById('bazi-form') as HTMLFormElement;
form?.addEventListener('submit', (e) => {
  e.preventDefault();
  const dateInput = (document.getElementById('birth-date') as HTMLInputElement).value;
  const hourInput = (document.getElementById('birth-time') as HTMLSelectElement).value;
  if (!dateInput || !hourInput) return;

  const [year, month, day] = dateInput.split('-').map(Number);
  const hour = parseInt(hourInput);

  const [yearGan, yearZhi] = getYearGanZhi(year);
  const monthGan = getMonthGan(year, month);
  const monthZhi = getMonthZhi(month);
  const [dayGan, dayZhi] = getDayGanZhi(year, month, day);
  const hourGan = getHourGan(dayGan, hour);
  const hourZhi = getHourZhi(hour);

  const allGans = [yearGan, monthGan, dayGan, hourGan];
  const allZhis = [yearZhi, monthZhi, dayZhi, hourZhi];

  document.getElementById('year-gan')!.textContent = yearGan;
  document.getElementById('month-gan')!.textContent = monthGan;
  document.getElementById('day-gan')!.textContent = dayGan;
  document.getElementById('hour-gan')!.textContent = hourGan;
  document.getElementById('year-zhi')!.textContent = yearZhi;
  document.getElementById('month-zhi')!.textContent = monthZhi;
  document.getElementById('day-zhi')!.textContent = dayZhi;
  document.getElementById('hour-zhi')!.textContent = hourZhi;

  document.getElementById('year-wuxing')!.textContent = `${ganWuxing[yearGan]}${zhiWuxing[yearZhi]}`;
  document.getElementById('month-wuxing')!.textContent = `${ganWuxing[monthGan]}${zhiWuxing[monthZhi]}`;
  document.getElementById('day-wuxing')!.textContent = `${ganWuxing[dayGan]}${zhiWuxing[dayZhi]}`;
  document.getElementById('hour-wuxing')!.textContent = `${ganWuxing[hourGan]}${zhiWuxing[hourZhi]}`;

  document.getElementById('year-shishen')!.textContent = getShiShen(dayGan, yearGan);
  document.getElementById('month-shishen')!.textContent = getShiShen(dayGan, monthGan);
  document.getElementById('hour-shishen')!.textContent = getShiShen(dayGan, hourGan);

  document.getElementById('nayin-year')!.textContent = naYin[yearGan + yearZhi] || '';
  document.getElementById('nayin-month')!.textContent = naYin[monthGan + monthZhi] || '';
  document.getElementById('nayin-day')!.textContent = naYin[dayGan + dayZhi] || '';
  document.getElementById('nayin-hour')!.textContent = naYin[hourGan + hourZhi] || '';

  const stats: Record<string, number> = { '木': 0, '火': 0, '土': 0, '金': 0, '水': 0 };
  allGans.forEach(g => stats[ganWuxing[g]]++);
  allZhis.forEach(z => stats[zhiWuxing[z]]++);

  const colors: Record<string, string> = { '木': '#4a7c59', '火': '#c41e3a', '土': '#8b6914', '金': '#c5a456', '水': '#2c5f6e' };
  document.getElementById('wuxing-stats')!.innerHTML = Object.entries(stats).map(([w, c]) => {
    const bars = Array(c).fill('■').join('');
    return `<div class="text-center"><div style="color:${colors[w]}" class="text-2xl font-serif-cn">${w}</div><div class="text-gold text-sm mt-1">${bars || '—'}</div><div class="text-xs text-ink-light/50">${c}</div></div>`;
  }).join('');

  document.getElementById('canggan-grid')!.innerHTML = allZhis.map(zhi => {
    const cgs = cangGan[zhi] || [];
    const ss = cgs.map(cg => getShiShen(dayGan, cg)).join(' ');
    return `<div><div class="font-serif-cn text-2xl text-ink">${zhi}</div><div class="text-xs text-ink-light/60 mt-1">${cgs.join(' ')}</div><div class="text-xs text-gold mt-1">${ss}</div></div>`;
  }).join('');

  const wuxingChars = ['木', '火', '土', '金', '水'];
  const missing = wuxingChars.filter(w => stats[w] === 0);
  const strongest = wuxingChars.reduce((a, b) => stats[a] > stats[b] ? a : b);
  const strongDesc: Record<string, string> = {
    '木': '仁爱心，生发向上', '火': '礼仪之德，热情明朗',
    '土': '诚信厚道，沉稳包容', '金': '义气果断，刚毅明理', '水': '智慧灵动，善于变通'
  };

  document.getElementById('ai-analysis')!.innerHTML = `
    <p class="mb-4">日主为<strong class="text-ink">${dayGan}${dayZhi}</strong>，${dayGan}属${ganWuxing[dayGan]}，${ganYinYang[dayGan]}性。日干代表命主自身，是八字分析的核心。</p>
    <p class="mb-4">五行分布：${wuxingChars.map(w => `${w} ${stats[w]}`).join(' · ')}</p>
    ${missing.length > 0 ? `<p class="mb-4">五行中缺<strong class="text-vermilion">${missing.join('、')}</strong>，可在日常生活中适当补益相关的色彩、方位与事物。</p>` : ''}
    <p class="mb-4">五行中<strong class="text-gold">${strongest}</strong>最旺，${strongest}旺者多有${strongDesc[strongest]}之性。</p>
    <p class="text-ink-light/50 mt-4">以上为五行基础分析，完整的八字推演还需考虑十神关系、格局、大运流年等诸多因素。</p>
  `;

  document.getElementById('bazi-result')!.classList.remove('hidden');
  document.getElementById('bazi-result')!.scrollIntoView({ behavior: 'smooth' });
});
</script>
