---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';
import { siteName, siteUrl } from '@data/site';

const allBooks = await getCollection('books');
const books = allBooks.filter((b) => !b.data.draft);

const categoryMeta = {
  shan: { name: '山', label: '山 · 修仙养性', icon: '⛰', desc: '道藏经典、内丹修炼、气功导引' },
  yi: { name: '医', label: '医 · 中医方药', icon: '💊', desc: '中医理论、方剂本草、针灸脉学' },
  ming: { name: '命', label: '命 · 命理推演', icon: '📜', desc: '八字、紫微、命理经典' },
  xiang: { name: '相', label: '相 · 形貌观察', icon: '🔍', desc: '面相手相、风水形法、相术经典' },
  bu: { name: '卜', label: '卜 · 占卜预测', icon: '🪙', desc: '六爻、奇门、占卜预测经典' },
};

// Books grouped by category
const booksByCategory = {};
books.forEach((b) => {
  const cat = b.data.category;
  if (!booksByCategory[cat]) booksByCategory[cat] = [];
  booksByCategory[cat].push(b);
});

// Featured books (first 4)
const featuredBooks = books.slice(0, 4);

// Category order for sidebar
const categoryOrder = ['shan', 'yi', 'ming', 'xiang', 'bu'];
const subCategories = {
  shan: ['道藏', '丹经', '功法'],
  yi: ['中医', '本草', '针灸'],
  ming: ['八字', '紫微斗数', '七政四余'],
  xiang: ['地相', '人相', '星相'],
  bu: ['易经', '六爻', '梅花易数', '奇门遁甲', '大六壬'],
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首页", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "国学书库", "item": `${siteUrl}/books/` },
  ],
};
---

<BaseLayout
  title={`国学书库 - ${siteName}`}
  description="五术典籍收藏，山医命相卜国学经典在线阅读，涵盖八字、紫微、周易、奇门遁甲等命理典籍"
  keywords="国学书库,五术典籍,山医命相卜,八字书籍,紫微书籍,周易书籍,奇门书籍,命理书籍"
  jsonLd={breadcrumbJsonLd}
>
  <Header />

  <section class="pt-28 pb-16 bg-gradient-to-br from-paper via-paper-dark to-[#e8e2d4] relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-serif-cn text-4xl md:text-5xl font-bold text-ink mb-4">国学书库</h1>
      <p class="text-lg text-ink-light/70 max-w-2xl mx-auto leading-relaxed">山医命相卜 · 五术典籍收藏 · 传承千年智慧</p>
    </div>
  </section>

  <!-- Main Layout: Sidebar + Content -->
  <section class="py-12 bg-[#f5f3ef]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Left Sidebar -->
        <aside class="lg:w-52 shrink-0">
          <div class="lg:sticky lg:top-24 bg-white rounded-2xl p-4 shadow-sm border border-gold/10">
            <div class="text-xs text-gold font-medium tracking-widest mb-4 hidden lg:block">五术分类</div>
            <nav class="flex lg:flex-col gap-1 overflow-x-auto lg:overflow-x-visible pb-2 lg:pb-0">
              {categoryOrder.map((cat) => {
                const meta = categoryMeta[cat];
                const count = (booksByCategory[cat] || []).length;
                const active = cat === 'ming'; // default active
                return (
                  <a href={`#${cat}`} class={`book-nav-link shrink-0 lg:shrink flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm transition-all whitespace-nowrap ${active ? 'bg-gold/10 text-gold font-medium' : 'text-ink-light/60 hover:bg-paper hover:text-ink'}`}>
                    <span class="text-base">{meta.icon}</span>
                    <span class="hidden lg:inline">{meta.name}</span>
                    <span class="hidden lg:inline text-xs opacity-50 ml-auto">{count > 0 ? count : '—'}</span>
                  </a>
                );
              })}
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 min-w-0">
          <!-- Featured Section -->
          {featuredBooks.length > 0 && (
            <div class="mb-12">
              <div class="flex items-center gap-3 mb-6">
                <span class="w-1 h-5 bg-gold rounded-full"></span>
                <h2 class="font-serif-cn text-xl font-bold text-ink">书库精选</h2>
              </div>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                {featuredBooks.map((book) => (
                  <a href={`/books/${book.slug}/`} class="group">
                    <div class="bg-white rounded-xl overflow-hidden border border-gold/10 shadow-sm card-hover">
                      <div class="aspect-[3/4] bg-gradient-to-br from-ink/80 to-ink/40 flex items-center justify-center relative overflow-hidden">
                        <div class="absolute inset-0 bg-pattern opacity-10"></div>
                        <div class="text-center relative z-10 px-3">
                          <div class="font-serif-cn text-lg font-bold text-gold mb-1 group-hover:text-white transition-colors">{book.data.title}</div>
                          {book.data.dynasty && <div class="text-xs text-paper/50">[{book.data.dynasty}]</div>}
                        </div>
                      </div>
                      <div class="p-3">
                        <div class="font-serif-cn text-sm font-bold text-ink truncate">{book.data.title}</div>
                        <div class="text-xs text-ink-light/50 mt-0.5">[{book.data.dynasty || ''}] {book.data.author}</div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Books by Category */}
          {categoryOrder.map((catKey) => {
            const meta = categoryMeta[catKey];
            const catBooks = booksByCategory[catKey] || [];
            if (catBooks.length === 0) return null;
            return (
              <div id={catKey} class="mb-12 scroll-mt-24">
                <div class="flex items-center gap-3 mb-6">
                  <span class="w-1 h-5 bg-gold rounded-full"></span>
                  <h2 class="font-serif-cn text-xl font-bold text-ink">{meta.label}</h2>
                  <span class="text-xs text-ink-light/40">{meta.desc}</span>
                </div>

                {/* Book List */}
                <div class="space-y-3">
                  {catBooks.map((book, i) => (
                    <a href={`/books/${book.slug}/`} class="flex items-start gap-4 bg-white rounded-xl p-4 border border-gold/10 card-hover no-underline fade-in-up group">
                      {/* Rank number */}
                      <div class="font-serif-cn text-lg font-bold text-gold/60 shrink-0 w-6 text-center pt-1">{i + 1}</div>
                      {/* Book cover */}
                      <div class="w-16 h-24 bg-gradient-to-br from-ink/80 to-ink/40 rounded-lg shrink-0 flex items-center justify-center overflow-hidden shadow-sm">
                        <div class="font-serif-cn text-xs font-bold text-gold text-center leading-tight px-1">{book.data.title}</div>
                      </div>
                      {/* Book info */}
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                          <h3 class="font-serif-cn text-base font-bold text-ink group-hover:text-vermilion transition-colors truncate">{book.data.title}</h3>
                        </div>
                        <div class="text-xs text-ink-light/50 mb-1.5">[{book.data.dynasty || ''}] {book.data.author}</div>
                        <p class="text-sm text-ink-light/70 line-clamp-2">{book.data.description}</p>
                      </div>
                      {/* Arrow */}
                      <div class="text-ink-light/30 group-hover:text-gold transition-colors shrink-0 pt-2">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}

          {/* Empty state if no books */}
          {books.length === 0 && (
            <div class="text-center py-20">
              <div class="text-6xl mb-4">📚</div>
              <h3 class="font-serif-cn text-xl font-bold text-ink mb-2">书库建设中</h3>
              <p class="text-ink-light/60">我们正在整理收录五术经典典籍，敬请期待！</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const els = document.querySelectorAll('.fade-in-up');
    const obs = new IntersectionObserver((e) => e.forEach((x) => { if (x.isIntersecting) x.target.classList.add('visible'); }), { threshold: 0.1 });
    els.forEach((el) => obs.observe(el));

    // Smooth scroll for sidebar links
    document.querySelectorAll('.book-nav-link[href^="#"]').forEach((link) => {
      link.addEventListener('click', (e) => {
        const target = document.querySelector(link.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });
  });
</script>
