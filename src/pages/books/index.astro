---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { siteName } from '@data/site';

const wuShu = [
  {
    name: '山',
    fullName: '山 — 修仙养性',
    desc: '修道养性、符咒斋醮、丹道气功、导引养生之法。涵盖道教经典、内丹修炼、气功导引等内容。',
    books: '即将上线',
    icon: '⛰',
    color: 'from-jade to-jade-light',
    examples: ['道德经', '周易参同契', '黄庭经', '太上感应篇'],
  },
  {
    name: '医',
    fullName: '医 — 中医方药',
    desc: '中医理论与实践，包括方剂、针灸、本草、脉诊等。以《黄帝内经》《伤寒论》等为代表的医学典籍。',
    books: '即将上线',
    icon: '💊',
    color: 'from-vermilion to-vermilion-light',
    examples: ['黄帝内经', '伤寒杂病论', '本草纲目', '难经'],
  },
  {
    name: '命',
    fullName: '命 — 命理推演',
    desc: '以八字、紫微斗数、六爻等为代表的命理典籍。研究人的命运规律，推演人生轨迹的传统学问。',
    books: '即将上线',
    icon: '📜',
    color: 'from-gold to-gold-light',
    examples: ['渊海子平', '滴天髓', '紫微斗数全书', '穷通宝鉴'],
  },
  {
    name: '相',
    fullName: '相 — 形貌观察',
    desc: '面相、手相、风水形法等通过观察外在形态推断内在品质的学问。包括阳宅、阴宅选址与布局。',
    books: '即将上线',
    icon: '🔍',
    color: 'from-water to-water-light',
    examples: ['葬书', '撼龙经', '麻衣相法', '柳庄相法'],
  },
  {
    name: '卜',
    fullName: '卜 — 占卜预测',
    desc: '以周易六十四卦、奇门遁甲、大六壬等为代表的占卜典籍。通过特定方法预测未来趋势的古老智慧。',
    books: '即将上线',
    icon: '🪙',
    color: 'from-earth to-earth-light',
    examples: ['周易', '奇门遁甲秘笈', '大六壬指南', '卜筮正宗'],
  },
];
---

<BaseLayout title={`国学书库 - ${siteName}`} description="五术典籍收藏，山医命相卜国学经典在线阅读">
  <Header />

  <!-- Hero -->
  <section class="pt-28 pb-16 bg-gradient-to-br from-paper via-paper-dark to-[#e8e2d4] relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="absolute top-20 right-20 w-96 h-96 opacity-5 taiji-spin hidden lg:block">
      <svg viewBox="0 0 200 200" fill="none"><circle cx="100" cy="100" r="90" stroke="#c5a456" stroke-width="2"/><path d="M100 10A90 90 0 0 1 100 190A45 45 0 0 0 100 100A45 45 0 0 1 100 10Z" fill="#c5a456"/><circle cx="100" cy="55" r="12" fill="#faf7f0"/><circle cx="100" cy="145" r="12" fill="#c5a456"/></svg>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-serif-cn text-4xl md:text-5xl font-bold text-ink mb-4">国学书库</h1>
      <p class="text-lg text-ink-light/70 max-w-2xl mx-auto leading-relaxed">山医命相卜 · 五术典籍收藏 · 传承千年智慧</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12 fade-in-up">
        <span class="section-label">关于书库</span>
        <h2 class="section-title">五术之学</h2>
        <div class="section-divider"></div>
      </div>
      <div class="font-sans-cn text-ink-light/80 leading-loose space-y-6 fade-in-up">
        <p>"五术"是中国传统文化中对道家学术体系的总称，包括山、医、命、相、卜五大门类。这一体系涵盖了从修身养性到预测推演的完整知识框架，是中华文明数千年智慧的结晶。</p>
        <p>书库致力于收集整理五术经典典籍，以数字化方式呈现，方便读者学习查阅。所有内容仅供学术研究与文化传承参考。</p>
      </div>
    </div>
  </section>

  <!-- 五术分类 -->
  <section class="py-16 bg-paper">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 fade-in-up">
        <span class="section-label">分类导航</span>
        <h2 class="section-title">五术分类</h2>
        <div class="section-divider"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {wuShu.map((ws, i) => (
          <div class="bg-white rounded-2xl border border-gold/10 overflow-hidden card-hover fade-in-up group" style={`transition-delay: ${i * 100}ms;`}>
            <div class={`h-2 bg-gradient-to-r ${ws.color}`}></div>
            <div class="p-6">
              <div class="flex items-start gap-4 mb-4">
                <div class={`w-14 h-14 bg-gradient-to-br ${ws.color} rounded-xl flex items-center justify-center shadow-md text-2xl`}>
                  {ws.icon}
                </div>
                <div>
                  <h3 class="font-serif-cn text-xl font-bold text-ink">{ws.name}</h3>
                  <p class="text-xs text-ink-light/50">{ws.fullName.split('—')[1]}</p>
                </div>
              </div>
              <p class="text-sm text-ink-light/70 leading-relaxed mb-4">{ws.desc}</p>

              <!-- Representative books -->
              <div class="mb-4">
                <div class="text-xs text-ink-light/40 mb-2">代表典籍</div>
                <div class="flex flex-wrap gap-2">
                  {ws.examples.map((ex) => (
                    <span class="text-xs bg-paper px-2.5 py-1 rounded-full text-ink-light/70 border border-gold/5">{ex}</span>
                  ))}
                </div>
              </div>

              <div class="pt-3 border-t border-gold/10 flex items-center justify-between">
                <span class="text-xs text-ink-light/40">藏书数量</span>
                <span class="text-sm font-serif-cn text-gold font-bold">{ws.books}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Coming Soon -->
  <section class="py-20 bg-gradient-to-br from-ink to-ink-light text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 border border-gold/30 rounded-full taiji-spin"></div>
    </div>
    <div class="max-w-3xl mx-auto px-4 text-center relative z-10">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-gold/20 rounded-full mb-6">
        <svg class="w-8 h-8 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
      </div>
      <h2 class="font-serif-cn text-3xl md:text-4xl font-bold mb-4">书库建设中</h2>
      <p class="text-paper/70 text-lg mb-8 leading-relaxed">我们正在整理收录五术经典典籍，涵盖山医命相卜五大门类。敬请期待！</p>
      <div class="flex flex-wrap items-center justify-center gap-8 text-paper/40 text-sm">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>持续收录中</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>五术全涵盖</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          <span>经典原版</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const els = document.querySelectorAll('.fade-in-up');
    const obs = new IntersectionObserver((e) => e.forEach((x) => { if (x.isIntersecting) x.target.classList.add('visible'); }), { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    els.forEach((el) => obs.observe(el));
  });
</script>
