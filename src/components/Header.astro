---
import { navLinks, siteName } from '@data/site';
---

<header id="header01" role="banner" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 bg-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <a href="/" class="flex items-center gap-3 no-underline group" aria-label={`${siteName} 首页`}>
        <div class="relative w-10 h-10 flex items-center justify-center">
          <svg class="w-8 h-8 text-vermilion" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 2A10 10 0 0 1 12 22A5 5 0 0 0 12 12A5 5 0 0 1 12 2Z" fill="currentColor"/>
            <circle cx="12" cy="7" r="1.5" fill="currentColor" class="text-paper"/>
            <circle cx="12" cy="17" r="1.5" fill="currentColor"/>
          </svg>
        </div>
        <div class="flex flex-col">
          <span class="font-serif-cn text-xl font-bold text-ink tracking-widest">{siteName}</span>
          <span class="text-xs text-earth tracking-widest">传承千年智慧</span>
        </div>
      </a>

      <nav class="hidden md:flex items-center gap-6 lg:gap-8" aria-label="主导航">
        {navLinks.map((link) => {
          const isActive = !link.external && !link.dropdown && Astro.url.pathname === link.href;
          const linkClass = [
            'hover:text-vermilion transition-colors duration-300 text-sm font-medium tracking-wide no-underline',
            isActive ? 'text-vermilion' : 'text-ink',
            link.dropdown && 'relative group',
          ].filter(Boolean).join(' ');

          if (link.dropdown) {
            return (
              <div class={linkClass}>
                <button class="flex items-center gap-1 cursor-pointer text-inherit font-inherit">
                  {link.label}
                  <svg class="w-3 h-3 transition-transform group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
                </button>
                <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                  <div class="bg-white rounded-xl shadow-lg border border-gold/10 py-2 min-w-[160px]">
                    {link.children.map((child) => (
                      <a href={child.href} class="block px-5 py-2.5 text-sm text-ink hover:bg-paper hover:text-vermilion transition-colors no-underline whitespace-nowrap">
                        {child.icon && <span class="mr-2">{child.icon}</span>}
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            );
          }

          return (
            link.external ? (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class={linkClass}
              >
                {link.label}
                <svg class="w-3 h-3 inline-block ml-0.5 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            ) : (
              <a href={link.href} class={linkClass}>
                {link.label}
              </a>
            )
          );
        })}
      </nav>

      <div class="flex items-center gap-4">
        <button id="mobile-menu-btn" class="md:hidden text-2xl text-ink" aria-label="菜单" aria-expanded="false">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 6h18M3 12h18M3 18h18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-paper border-t border-gold/20 max-h-[80vh] overflow-y-auto">
    <nav class="px-4 py-4 space-y-2" aria-label="移动端导航">
      {navLinks.map((link) => (
        link.dropdown ? (
          <div class="mobile-dropdown">
            <button class="mobile-dropdown-toggle flex items-center justify-between w-full text-ink py-2 text-sm hover:text-vermilion transition-colors">
              {link.label}
              <svg class="w-4 h-4 mobile-dropdown-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="mobile-dropdown-content hidden pl-4 space-y-1">
              {link.children.map((child) => (
                <a href={child.href} class="block py-2 text-sm text-ink-light/70 hover:text-vermilion transition-colors no-underline">
                  {child.icon && <span class="mr-2">{child.icon}</span>}
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : link.external ? (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="flex items-center block text-ink py-2 text-sm no-underline hover:text-vermilion transition-colors">
            {link.label}
            <svg class="w-3 h-3 inline-block ml-1 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        ) : (
          <a href={link.href} class="block text-ink py-2 text-sm no-underline hover:text-vermilion transition-colors">
            {link.label}
          </a>
        )
      ))}
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('header01');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('nav-scrolled');
    } else {
      header?.classList.remove('nav-scrolled');
    }
  });

  if (mobileBtn && mobileMenu) {
    mobileBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Mobile dropdown toggles
    mobileMenu.querySelectorAll('.mobile-dropdown-toggle').forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const content = toggle.nextElementSibling;
        const chevron = toggle.querySelector('.mobile-dropdown-chevron');
        content.classList.toggle('hidden');
        chevron?.classList.toggle('rotate-180');
      });
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  }
</script>
