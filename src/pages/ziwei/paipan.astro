---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { siteName } from '@data/site';

const diZhi = ['子', '丑', '寅', '卯', '辰', '巳', '午', '未', '申', '酉', '戌', '亥'];
const zhuXing = ['紫微', '天机', '太阳', '武曲', '天同', '廉贞', '天府', '太阴', '贪狼', '巨门', '天相', '天梁', '七杀', '破军'];
const gongNames = ['命宫', '兄弟', '夫妻', '子女', '财帛', '疾厄', '迁移', '交友', '官禄', '田宅', '福德', '父母'];
---

<BaseLayout title={`紫微排盘 - ${siteName}`} description="紫微斗数在线排盘工具">
  <Header />

  <section class="pt-28 pb-16 bg-gradient-to-br from-paper via-paper-dark to-[#e8e2d4] relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-br from-jade to-jade-light rounded-full flex items-center justify-center shadow-lg">
        <svg class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26"/></svg>
      </div>
      <h1 class="font-serif-cn text-4xl md:text-5xl font-bold text-ink mb-4">紫微排盘</h1>
      <p class="text-lg text-ink-light/70 max-w-2xl mx-auto leading-relaxed">输入出生年月日时，排出紫微命盘</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Input Form -->
      <div class="bg-paper rounded-2xl p-8 border border-gold/10 max-w-xl mx-auto mb-10 shadow-sm">
        <form id="ziwei-form" class="space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="ziwei-date" class="block text-sm font-serif-cn text-ink mb-1">出生日期</label>
              <input type="date" id="ziwei-date" required
                class="w-full px-4 py-3 border border-gold/30 rounded-xl bg-white font-sans-cn text-ink focus:border-jade focus:outline-none focus:ring-1 focus:ring-jade/30" />
            </div>
            <div>
              <label for="ziwei-time" class="block text-sm font-serif-cn text-ink mb-1">出生时辰</label>
              <select id="ziwei-time" required
                class="w-full px-4 py-3 border border-gold/30 rounded-xl bg-white font-sans-cn text-ink focus:border-jade focus:outline-none focus:ring-1 focus:ring-jade/30">
                <option value="">请选择时辰</option>
                <option value="23">子时 (23:00-01:00)</option>
                <option value="1">丑时 (01:00-03:00)</option>
                <option value="3">寅时 (03:00-05:00)</option>
                <option value="5">卯时 (05:00-07:00)</option>
                <option value="7">辰时 (07:00-09:00)</option>
                <option value="9">巳时 (09:00-11:00)</option>
                <option value="11">午时 (11:00-13:00)</option>
                <option value="13">未时 (13:00-15:00)</option>
                <option value="15">申时 (15:00-17:00)</option>
                <option value="17">酉时 (17:00-19:00)</option>
                <option value="19">戌时 (19:00-21:00)</option>
                <option value="21">亥时 (21:00-23:00)</option>
              </select>
            </div>
          </div>
          <button type="submit" class="w-full px-6 py-3 bg-jade text-white rounded-xl hover:bg-jade-light transition-all duration-300 font-serif-cn tracking-wider">
            开始排盘
          </button>
        </form>
      </div>

      <!-- Result -->
      <div id="ziwei-result" class="hidden space-y-8">
        <div class="bg-paper rounded-2xl p-8 border border-gold/10 shadow-sm">
          <h3 class="font-serif-cn text-xl text-ink text-center mb-8 tracking-widest">紫 微 命 盘</h3>
          <div id="gong-grid" class="grid grid-cols-3 md:grid-cols-4 gap-3"></div>
        </div>

        <!-- 十四主星介绍 -->
        <div class="bg-paper rounded-2xl p-8 border border-gold/10 shadow-sm">
          <h3 class="font-serif-cn text-xl text-ink text-center mb-6 tracking-widest">十四主星简介</h3>
          <div class="grid md:grid-cols-2 gap-3">
            {[
              { name: '紫微', type: '北斗', desc: '帝星，尊贵稳重，有领导力' },
              { name: '天机', type: '北斗', desc: '智谋之星，聪明善变' },
              { name: '太阳', type: '北斗', desc: '光明磊落，热情博爱' },
              { name: '武曲', type: '北斗', desc: '刚毅果断，善理财' },
              { name: '天同', type: '北斗', desc: '福星，温和随性' },
              { name: '廉贞', type: '北斗', desc: '复杂多变，才华横溢' },
              { name: '天府', type: '南斗', desc: '库星，稳重守成' },
              { name: '太阴', type: '南斗', desc: '温柔细腻，内敛含蓄' },
              { name: '贪狼', type: '南斗', desc: '欲望之星，多才多艺' },
              { name: '巨门', type: '南斗', desc: '口舌之星，能言善辩' },
              { name: '天相', type: '南斗', desc: '印星，公正平和' },
              { name: '天梁', type: '南斗', desc: '荫星，慈悲为怀' },
              { name: '七杀', type: '南斗', desc: '将星，果断勇猛' },
              { name: '破军', type: '南斗', desc: '耗星，变动创新' },
            ].map((star) => (
              <div class="flex items-start gap-3 bg-white rounded-lg p-4">
                <div class="font-serif-cn text-lg text-vermilion shrink-0 w-12">{star.name}</div>
                <div><div class="text-xs text-gold mb-1">{star.type}</div><div class="text-sm text-ink-light/70">{star.desc}</div></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
const diZhi = ['子', '丑', '寅', '卯', '辰', '巳', '午', '未', '申', '酉', '戌', '亥'];
const gongNames = ['命宫', '兄弟', '夫妻', '子女', '财帛', '疾厄', '迁移', '交友', '官禄', '田宅', '福德', '父母'];

function getMingGongIndex(month: number, hourZhiIndex: number): number {
  return ((2 + month - 1 - hourZhiIndex) % 12 + 12) % 12;
}

function getShenGongIndex(month: number, hourZhiIndex: number): number {
  return ((2 + month - 1 + hourZhiIndex) % 12);
}

function distributeStars(): Record<number, string[]> {
  const result: Record<number, string[]> = {};
  for (let i = 0; i < 12; i++) result[i] = [];
  const mainStars = ['紫微', '天机', '太阳', '武曲', '天同', '廉贞'];
  const secondaryStars = ['天府', '太阴', '贪狼', '巨门', '天相', '天梁', '七杀', '破军'];
  result[0].push('紫微');
  for (let i = 1; i < mainStars.length; i++) result[i % 12].push(mainStars[i]);
  for (let i = 0; i < secondaryStars.length; i++) {
    const pos = (i + 3) % 12;
    if (!result[pos].includes(secondaryStars[i])) result[pos].push(secondaryStars[i]);
  }
  return result;
}

function getHourZhiIndex(hour: number): number {
  if (hour >= 23 || hour < 1) return 0;
  return Math.floor((hour + 1) / 2);
}

const form = document.getElementById('ziwei-form') as HTMLFormElement;
form?.addEventListener('submit', (e) => {
  e.preventDefault();
  const dateInput = (document.getElementById('ziwei-date') as HTMLInputElement).value;
  const hourInput = (document.getElementById('ziwei-time') as HTMLSelectElement).value;
  if (!dateInput || !hourInput) return;

  const [year, month, day] = dateInput.split('-').map(Number);
  const hour = parseInt(hourInput);
  const hourZhiIndex = getHourZhiIndex(hour);
  const mingIndex = getMingGongIndex(month, hourZhiIndex);
  const shenIndex = getShenGongIndex(month, hourZhiIndex);
  const stars = distributeStars();

  const gridEl = document.getElementById('gong-grid')!;
  gridEl.innerHTML = Array.from({ length: 12 }, (_, i) => {
    const actualIndex = (i + mingIndex) % 12;
    const gw = gongNames[i];
    const gongStars = stars[actualIndex] || [];
    const isMing = i === 0;
    const isShen = actualIndex === shenIndex;
    return `<div class="p-4 border ${isMing ? 'border-vermilion bg-vermilion/5' : 'border-gold/20 bg-white'} rounded-xl text-center">
      <div class="font-serif-cn text-sm ${isMing ? 'text-vermilion font-bold' : 'text-ink'}">${gw}${isShen ? ' <span class="text-xs text-jade">(身)</span>' : ''}</div>
      <div class="font-serif-cn text-xl text-ink mt-1">${diZhi[actualIndex]}</div>
      ${gongStars.length > 0 ? `<div class="text-xs text-vermilion mt-1">${gongStars.join(' ')}</div>` : '<div class="text-xs text-ink-light/40 mt-1">—</div>'}
    </div>`;
  }).join('');

  document.getElementById('ziwei-result')!.classList.remove('hidden');
  document.getElementById('ziwei-result')!.scrollIntoView({ behavior: 'smooth' });
});
</script>
