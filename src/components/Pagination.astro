---
interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;
---

{totalPages > 1 && (
  <nav class="flex items-center justify-center gap-2 mt-8" aria-label="分页">
    {currentPage > 1 ? (
      <a
        href={currentPage === 2 ? basePath : `${basePath}${currentPage - 1}/`}
        class="px-3 py-1.5 text-sm font-kai text-mo border border-tan/30 rounded-sm hover:border-jin hover:text-zhu transition-colors no-underline"
      >
        上一页
      </a>
    ) : (
      <span class="px-3 py-1.5 text-sm font-kai text-mo/30 border border-transparent rounded-sm">上一页</span>
    )}

    {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) =>
      page === currentPage ? (
        <span class="px-3 py-1.5 text-sm font-kai text-zhu bg-zhu/10 rounded-sm">{page}</span>
      ) : (
        <a
          href={page === 1 ? basePath : `${basePath}${page}/`}
          class="px-3 py-1.5 text-sm font-kai text-mo border border-tan/30 rounded-sm hover:border-jin hover:text-zhu transition-colors no-underline"
        >
          {page}
        </a>
      )
    )}

    {currentPage < totalPages ? (
      <a
        href={`${basePath}${currentPage + 1}/`}
        class="px-3 py-1.5 text-sm font-kai text-mo border border-tan/30 rounded-sm hover:border-jin hover:text-zhu transition-colors no-underline"
      >
        下一页
      </a>
    ) : (
      <span class="px-3 py-1.5 text-sm font-kai text-mo/30 border border-transparent rounded-sm">下一页</span>
    )}
  </nav>
)}
