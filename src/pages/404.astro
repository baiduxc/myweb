---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { siteName } from '@data/site';
---

<BaseLayout title={`404 - ${siteName}`} robots="noindex, nofollow">
  <Header />
  <main class="flex-1 flex items-center justify-center py-20">
    <div class="text-center">
      <div class="font-kai text-8xl text-tan/30 mb-4">404</div>
      <div class="font-kai text-2xl text-xuan mb-4">页面未找到</div>
      <p class="text-mo-light font-song mb-8">此页面如同走失的星辰，不在命盘之中。</p>
      <a href="/" class="btn-primary">返回首页</a>
    </div>
  </main>
  <Footer />
</BaseLayout>
