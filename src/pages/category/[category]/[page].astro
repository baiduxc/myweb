---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import SectionHeading from '@components/SectionHeading.astro';
import ArticleCard from '@components/ArticleCard.astro';
import Pagination from '@components/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteName } from '@data/site';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const categories = [...new Set(allPosts.map((p) => p.data.category))];
  const postsPerPage = 6;

  return categories.flatMap((category) => {
    const posts = allPosts
      .filter((p) => p.data.category === category && !p.data.draft)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

    const totalPages = Math.ceil(posts.length / postsPerPage);
    return Array.from({ length: totalPages || 1 }, (_, i) => ({
      params: { category, page: String(i + 1) },
      props: { posts: posts.slice(i * postsPerPage, (i + 1) * postsPerPage), category, currentPage: i + 1, totalPages },
    }));
  });
}

const { posts, category, currentPage, totalPages } = Astro.props;

const categoryMap: Record<string, { title: string; subtitle: string }> = {
  bazi: { title: '八字学堂', subtitle: '四柱八字基础知识与实战解析' },
  ziwei: { title: '紫微讲堂', subtitle: '紫微斗数基础与星曜宫位解读' },
  fengshui: { title: '风水基础', subtitle: '堪舆学入门与环境与人的关系' },
  wuxing: { title: '五行精要', subtitle: '五行生克制化的深入理解' },
  general: { title: '综合杂谈', subtitle: '命理知识的综合讨论' },
};

const catInfo = categoryMap[category] || { title: category, subtitle: '' };
---

<BaseLayout title={`${catInfo.title} - ${siteName}`} description={catInfo.subtitle}>
  <Header />

  <main class="max-w-6xl mx-auto px-4 py-10 flex-1">
    <SectionHeading title={catInfo.title} subtitle={catInfo.subtitle} />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <ArticleCard
          title={post.data.title}
          date={post.data.date.toISOString()}
          excerpt={post.data.description}
          slug={post.slug}
          category={catInfo.title.slice(0, 2)}
          tags={post.data.tags}
        />
      ))}
    </div>

    <Pagination currentPage={currentPage} totalPages={totalPages} basePath={`/category/${category}/`} />
  </main>

  <Footer />
</BaseLayout>
