---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';
import { siteName, siteUrl } from '@data/site';

const allPosts = await getCollection('blog');
const posts = allPosts.filter((p) => !p.data.draft && p.data.category === 'ziwei')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "首页",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "紫微斗数",
      "item": `${siteUrl}/ziwei/`
    }
  ]
};

const zhiShiModules = [
  { title: '十四主星', desc: '紫微系（紫微、天机、太阳、武曲、天同、廉贞）与天府系（天府、太阴、贪狼、巨门、天相、天梁、七杀、破军）的特性与庙旺落陷。', icon: '01' },
  { title: '十二宫位', desc: '命宫、兄弟、夫妻、子女、财帛、疾厄、迁移、交友、官禄、田宅、福德、父母，十二宫位各主何事，宫位之间的三合六冲关系。', icon: '02' },
  { title: '四化飞星', desc: '化禄（财禄）、化权（权势）、化科（名声）、化忌（阻滞），四化随年干变化，是判断吉凶变化的核心依据。', icon: '03' },
  { title: '辅星杂曜', desc: '文昌、文曲、左辅、右弼、天魁、天钺等吉星，以及擎羊、陀罗、火星、铃星、地空、地劫等煞星的影响。', icon: '04' },
  { title: '三方四正', desc: '命宫、财帛宫、官禄宫构成三合，加上迁移宫构成四正。三方四正的综合分析是紫微断命的核心方法。', icon: '05' },
  { title: '大运流年', desc: '以命宫为起点，每十年行一大限，配合流年小限，分析各阶段的运势起伏与关键时间节点。', icon: '06' },
];

const zhuXing = [
  { name: '紫微', type: '北斗', desc: '帝星，尊贵稳重，有领导力' },
  { name: '天机', type: '北斗', desc: '智谋之星，聪明善变' },
  { name: '太阳', type: '北斗', desc: '光明磊落，热情博爱' },
  { name: '武曲', type: '北斗', desc: '刚毅果断，善理财' },
  { name: '天同', type: '北斗', desc: '福星，温和随性' },
  { name: '廉贞', type: '北斗', desc: '复杂多变，才华横溢' },
  { name: '天府', type: '南斗', desc: '库星，稳重守成' },
  { name: '太阴', type: '南斗', desc: '温柔细腻，内敛含蓄' },
  { name: '贪狼', type: '南斗', desc: '欲望之星，多才多艺' },
  { name: '巨门', type: '南斗', desc: '口舌之星，能言善辩' },
  { name: '天相', type: '南斗', desc: '印星，公正平和' },
  { name: '天梁', type: '南斗', desc: '荫星，慈悲为怀' },
  { name: '七杀', type: '南斗', desc: '将星，果断勇猛' },
  { name: '破军', type: '南斗', desc: '耗星，变动创新' },
];

const gongWei = [
  { name: '命宫', desc: '性格、天赋、人生基调' },
  { name: '兄弟', desc: '兄弟姐妹、同辈关系' },
  { name: '夫妻', desc: '婚姻感情、配偶特质' },
  { name: '子女', desc: '子女缘、教育方式' },
  { name: '财帛', desc: '财运、理财能力' },
  { name: '疾厄', desc: '健康、体质' },
  { name: '迁移', desc: '出行、人际、外在表现' },
  { name: '交友', desc: '朋友、同事、社交' },
  { name: '官禄', desc: '事业、学业、地位' },
  { name: '田宅', desc: '房产、家庭环境' },
  { name: '福德', desc: '精神享受、福气' },
  { name: '父母', desc: '父母关系、长辈缘' },
];
---

<BaseLayout 
  title={`紫微斗数 - ${siteName}`} 
  description="系统学习紫微斗数命理，详解十四主星、十二宫位、四化飞星、大运流年，掌握紫微排盘与命盘解读方法" 
  keywords="紫微斗数,紫微,斗数,十四主星,十二宫位,命宫,流年,四化,飞星,紫微排盘"
  jsonLd={breadcrumbJsonLd}
>
  <Header />

  <!-- Hero -->
  <section class="pt-28 pb-16 bg-gradient-to-br from-paper via-paper-dark to-[#e8e2d4] relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="absolute top-20 right-20 w-96 h-96 opacity-5 taiji-spin hidden lg:block">
      <svg viewBox="0 0 200 200" fill="none"><circle cx="100" cy="100" r="90" stroke="#4a7c59" stroke-width="2"/><path d="M100 10A90 90 0 0 1 100 190A45 45 0 0 0 100 100A45 45 0 0 1 100 10Z" fill="#4a7c59"/><circle cx="100" cy="55" r="12" fill="#faf7f0"/><circle cx="100" cy="145" r="12" fill="#4a7c59"/></svg>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-serif-cn text-4xl md:text-5xl font-bold text-ink mb-4">紫微斗数</h1>
      <p class="text-lg text-ink-light/70 max-w-2xl mx-auto leading-relaxed">十四主星详解 · 十二宫位推断 · 观星曜而知命运</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12 fade-in-up"><span class="section-label">概述</span><h2 class="section-title">走进紫微斗数</h2><div class="section-divider"></div></div>
      <div class="font-sans-cn text-ink-light/80 leading-loose space-y-6 fade-in-up">
        <p>紫微斗数，简称"紫微"，是中国传统命理学中的重要流派。它以人的出生年月日时为基础，排出命盘，将诸星分布于十二宫位中，通过星曜的庙旺落陷、吉凶组合来推断命运。</p>
        <p>紫微斗数以紫微星为核心，布十四主星于命盘十二宫位。每颗星曜都有其独特的含义和特性，在不同宫位中表现出不同的影响。通过分析星曜之间的组合关系，可以推断人的性格、事业、财运、婚姻、健康等各方面的运势。</p>
      </div>
    </div>
  </section>

  <!-- Knowledge Structure -->
  <section class="py-16 bg-paper">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 fade-in-up">
        <span class="section-label">知识体系</span>
        <h2 class="section-title">紫微核心知识</h2>
        <div class="section-divider"></div>
        <p class="mt-6 text-ink-light/70 max-w-2xl mx-auto">从星曜到宫位，系统掌握紫微斗数的六大知识模块</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {zhiShiModules.map((mod, i) => (
          <div class="bg-white rounded-2xl p-6 border border-gold/10 card-hover fade-in-up group" style={`transition-delay: ${i * 80}ms;`}>
            <div class="w-12 h-12 mb-4 bg-gradient-to-br from-jade/10 to-jade/5 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <span class="font-serif-cn text-lg font-bold text-jade">{mod.icon}</span>
            </div>
            <h3 class="font-serif-cn text-lg font-bold text-ink mb-3 group-hover:text-jade transition-colors">{mod.title}</h3>
            <p class="text-sm text-ink-light/70 leading-relaxed">{mod.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 十四主星 -->
  <section class="py-16 bg-paper">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12 fade-in-up"><span class="section-label">核心星曜</span><h2 class="section-title">十四主星</h2><div class="section-divider"></div></div>
      <div class="grid md:grid-cols-2 gap-4">
        {zhuXing.map((star, i) => (
          <div class="flex items-start gap-4 bg-white rounded-xl p-5 border border-gold/10 card-hover fade-in-up" style={`transition-delay: ${i * 50}ms;`}>
            <div class={`font-serif-cn text-lg shrink-0 w-14 py-1 text-center rounded-lg ${star.type === '北斗' ? 'bg-vermilion/10 text-vermilion' : 'bg-jade/10 text-jade'}`}>
              {star.name}
            </div>
            <div>
              <div class="text-xs text-gold mb-1">{star.type}</div>
              <div class="text-sm text-ink-light/70">{star.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 十二宫位 -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12 fade-in-up"><span class="section-label">宫位系统</span><h2 class="section-title">十二宫位</h2><div class="section-divider"></div></div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {gongWei.map((gw, i) => (
          <div class="bg-paper rounded-xl p-4 text-center border border-gold/10 card-hover fade-in-up" style={`transition-delay: ${i * 50}ms;`}>
            <div class="font-serif-cn text-lg font-bold text-ink mb-1">{gw.name}</div>
            <div class="text-xs text-ink-light/60">{gw.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Articles -->
  {posts.length > 0 && (
    <section class="py-16 bg-paper">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-12 fade-in-up"><span class="section-label">相关文章</span><h2 class="section-title">推荐阅读</h2><div class="section-divider"></div></div>
        <div class="space-y-6">{posts.map((p) => (<a href={`/blog/${p.slug}/`} class="block bg-white rounded-xl p-6 border border-gold/5 card-hover no-underline fade-in-up"><h3 class="font-serif-cn text-lg font-bold text-ink mb-2 hover:text-vermilion transition-colors">{p.data.title}</h3><p class="text-sm text-ink-light/70 line-clamp-2">{p.data.description}</p><div class="text-xs text-ink-light/50 mt-3">{p.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</div></a>))}</div>

        <div class="text-center mt-10">
          <a href="/articles/" class="btn-outline">
            <span>查看更多文章</span>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const els = document.querySelectorAll('.fade-in-up');
    const obs = new IntersectionObserver((e) => e.forEach((x) => { if (x.isIntersecting) x.target.classList.add('visible'); }), { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    els.forEach((el) => obs.observe(el));
  });
</script>
