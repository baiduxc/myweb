---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';
import { siteName } from '@data/site';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((book) => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const rendered = await book.render();
const { Content } = rendered;

const categoryMeta = {
  shan: { name: '山', label: '山 · 修仙养性' },
  yi: { name: '医', label: '医 · 中医方药' },
  ming: { name: '命', label: '命 · 命理推演' },
  xiang: { name: '相', label: '相 · 形貌观察' },
  bu: { name: '卜', label: '卜 · 占卜预测' },
};

const cat = categoryMeta[book.data.category] || { name: '?', label: book.data.category };

// Get all books in same category for sidebar
const allBooks = await getCollection('books');
const relatedBooks = allBooks
  .filter((b) => !b.data.draft && b.data.category === book.data.category && b.slug !== book.slug)
  .slice(0, 5);

// Extract headings from content for TOC
const headings = [];
const tocMatch = rendered.body?.match(/<h([23])[^>]*>(.*?)<\/h\1>/g);
if (tocMatch) {
  tocMatch.forEach((h) => {
    const level = h.match(/<h([23])/)[1];
    const text = h.replace(/<[^>]+>/g, '').trim();
    headings.push({ level: parseInt(level), text });
  });
}
---

<BaseLayout title={`${book.data.title} - ${siteName}`} description={book.data.description}>
  <Header />

  <section class="pt-28 pb-16 bg-gradient-to-br from-paper via-paper-dark to-[#e8e2d4] relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-serif-cn text-4xl md:text-5xl font-bold text-ink mb-4">国学书库</h1>
      <p class="text-lg text-ink-light/70 max-w-2xl mx-auto leading-relaxed">山医命相卜 · 五术典籍收藏 · 传承千年智慧</p>
    </div>
  </section>

  <!-- Main Layout: Sidebar + Content -->
  <section class="py-12 bg-[#f5f3ef]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Left Sidebar: Category Nav + Book List -->
        <aside class="lg:w-52 shrink-0">
          <div class="lg:sticky lg:top-24 bg-white rounded-2xl p-4 shadow-sm border border-gold/10">
            <div class="text-xs text-gold font-medium tracking-widest mb-4 hidden lg:block">五术分类</div>
            <nav class="flex lg:flex-col gap-1 overflow-x-auto lg:overflow-x-visible pb-2 lg:pb-0">
              {Object.entries(categoryMeta).map(([key, meta]) => {
                const count = allBooks.filter((b) => !b.data.draft && b.data.category === key).length;
                const isActive = key === book.data.category;
                return (
                  <a href={`/books/`} class={`book-nav-link shrink-0 lg:shrink flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm transition-all whitespace-nowrap ${isActive ? 'bg-gold/10 text-gold font-medium' : 'text-ink-light/60 hover:bg-paper hover:text-ink'}`}>
                    <span class="text-base">{meta.name}</span>
                    <span class="hidden lg:inline text-xs opacity-50 ml-auto">{count > 0 ? count : '—'}</span>
                  </a>
                );
              })}
            </nav>

            {relatedBooks.length > 0 && (
              <div class="mt-6 pt-4 border-t border-gold/10 hidden lg:block">
                <div class="text-xs text-gold font-medium tracking-widest mb-3">同分类推荐</div>
                <div class="space-y-2">
                  {relatedBooks.map((rb) => (
                    <a href={`/books/${rb.slug}/`} class="block text-xs text-ink-light/60 hover:text-vermilion transition-colors truncate py-1">
                      {rb.data.title}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </aside>

        <!-- Main Content: Book Detail -->
        <div class="flex-1 min-w-0">
          <!-- Back link -->
          <a href="/books/" class="inline-flex items-center gap-2 text-sm text-ink-light/60 hover:text-vermilion transition-colors mb-6 no-underline fade-in-up">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
            返回书库
          </a>

          <!-- Book Header -->
          <div class="bg-white rounded-2xl p-6 md:p-8 border border-gold/10 shadow-sm mb-8 fade-in-up">
            <div class="flex flex-col md:flex-row gap-6">
              <!-- Book Cover -->
              <div class="w-32 h-44 bg-gradient-to-br from-ink/80 to-ink/40 rounded-xl shrink-0 flex items-center justify-center shadow-md relative overflow-hidden">
                <div class="absolute inset-0 bg-pattern opacity-10"></div>
                <div class="text-center relative z-10 px-3">
                  <div class="font-serif-cn text-lg font-bold text-gold">{book.data.title}</div>
                  {book.data.dynasty && <div class="text-xs text-paper/50 mt-1">[{book.data.dynasty}]</div>}
                </div>
              </div>

              <!-- Book Info -->
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2 py-0.5 bg-gold/10 text-gold text-xs rounded-full font-medium">{cat.label.split('·')[0].trim()}</span>
                </div>
                <h1 class="font-serif-cn text-2xl md:text-3xl font-bold text-ink mb-3">{book.data.title}</h1>
                <div class="text-sm text-ink-light/60 mb-4">
                  <span>[{book.data.dynasty || '佚名'}] {book.data.author}</span>
                  <span class="mx-2">·</span>
                  <span>{cat.label}</span>
                </div>
                <p class="text-ink-light/70 leading-relaxed mb-6">{book.data.description}</p>
                <a href={`/books/${book.slug}/read/`} class="btn-primary">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                  <span>开始阅读</span>
                </a>
              </div>
            </div>
          </div>

          <!-- Content Preview -->
          {headings.length > 0 && (
            <div class="bg-white rounded-2xl p-6 md:p-8 border border-gold/10 shadow-sm mb-8 fade-in-up">
              <div class="flex items-center gap-3 mb-6">
                <svg class="w-5 h-5 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                <h2 class="font-serif-cn text-xl font-bold text-ink">目录章节</h2>
              </div>
              <div class="space-y-2">
                {headings.map((h) => (
                  <div class={`flex items-center gap-3 py-2 px-3 rounded-lg hover:bg-paper transition-colors ${h.level === 3 ? 'pl-8 text-sm text-ink-light/60' : 'font-medium text-ink'}`}>
                    <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${h.level === 3 ? 'bg-gold/40' : 'bg-gold'}`}></span>
                    <span>{h.text}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Content Preview -->
          <div class="bg-white rounded-2xl p-6 md:p-8 border border-gold/10 shadow-sm fade-in-up">
            <div class="flex items-center gap-3 mb-6">
              <svg class="w-5 h-5 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <h2 class="font-serif-cn text-xl font-bold text-ink">内容预览</h2>
            </div>
            <div class="prose prose-lg max-w-none font-sans-cn text-ink-light leading-loose
                        prose-headings:font-serif-cn prose-headings:text-ink prose-headings:tracking-wider
                        prose-h2:text-xl prose-h3:text-lg
                        prose-p:text-ink-light/80 prose-strong:text-ink">
              <Content />
            </div>
            <div class="mt-8 pt-6 border-t border-gold/10 text-center">
              <a href={`/books/${book.slug}/read/`} class="btn-primary">
                <span>阅读全书</span>
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const els = document.querySelectorAll('.fade-in-up');
    const obs = new IntersectionObserver((e) => e.forEach((x) => { if (x.isIntersecting) x.target.classList.add('visible'); }), { threshold: 0.1 });
    els.forEach((el) => obs.observe(el));
  });
</script>
